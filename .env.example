# OpenAI key is required only if using OpenAI LLM or OpenAI embeddings
OPENAI_API_KEY=your_openai_api_key_here

# Options: openai or local
EMBEDDING_PROVIDER=local

# Options: openai
LLM_PROVIDER=openai

# Model settings
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Retrieval settings
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=4
